# ══════════════════════════════════════════════════════════════════════════════
#  NODYX FRONTEND — Configuration
#  Copiez ce fichier en .env et adaptez les valeurs.
#  Les variables PUBLIC_* sont exposées côté client (navigateur).
# ══════════════════════════════════════════════════════════════════════════════

# URL racine du domaine Nodyx (sans slash final, sans /api/v1)
# En développement local : http://localhost:3000
# En production sur le même domaine (reverse proxy) : https://mondomaine.fr
# En production sur domaine séparé : https://api.mondomaine.fr
# IMPORTANT : ne pas ajouter /api/v1 ici — il est ajouté automatiquement
PUBLIC_API_URL=https://mondomaine.fr

# URL interne SSR — utilisée par SvelteKit côté serveur pour bypasser Caddy
# Ne modifier que si nexus-core tourne sur un port différent
PRIVATE_API_SSR_URL=http://127.0.0.1:3000/api/v1

# URL du directory Nodyx (ne modifier que si vous hébergez votre propre directory)
PUBLIC_DIRECTORY_URL=https://nexusnode.app

# ── WebRTC TURN server (optionnel) ────────────────────────────────────────────
# Requis quand les deux pairs sont derrière des NAT ou que le routeur ne
# supporte pas le hairpinning. Sans TURN, la connexion reste en "checking".
# PUBLIC_TURN_URL=turn:monserveur.com:3478
# PUBLIC_TURN_USERNAME=nodyx
# PUBLIC_TURN_CREDENTIAL=motdepasse

# ── Nodyx Signet (authentificateur PWA, optionnel) ───────────────────────────
# URL de l'instance Nodyx Signet hébergée — laisser vide si non utilisé
# PUBLIC_SIGNET_URL=https://signet.nexusnode.app
PUBLIC_SIGNET_URL=
