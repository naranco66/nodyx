# ══════════════════════════════════════════════════════════════════════════════
#  NODYX — Configuration de l'instance
#  Copiez ce fichier en .env et adaptez les valeurs.
#  Ne committez JAMAIS votre .env dans git.
# ══════════════════════════════════════════════════════════════════════════════

# ── Identité de la communauté ─────────────────────────────────────────────────
# Ces valeurs définissent votre instance. Une instance = une communauté.

# Nom affiché de la communauté (apparaît dans le titre, les balises meta, etc.)
NODYX_COMMUNITY_NAME=Ma Communauté

# Description courte (utilisée pour le SEO, la page d'accueil, le RSS)
NODYX_COMMUNITY_DESCRIPTION=La communauté dédiée à [votre sujet].

# Slug unique de la communauté — lettres minuscules, chiffres, tirets uniquement
# Exemple : linux, gaming, dev-web, photo
NODYX_COMMUNITY_SLUG=ma-communaute

# Langue principale du contenu (code ISO 639-1)
# Utilisé pour la recherche full-text PostgreSQL et les balises HTML lang=""
# Valeurs supportées : fr, en, de, es, it, pt, nl
NODYX_COMMUNITY_LANGUAGE=fr

# Pays (code ISO 3166-1 alpha-2, pour les balises meta geo)
NODYX_COMMUNITY_COUNTRY=FR

# Version de Nodyx installée (mise à jour automatiquement par install.sh)
NODYX_VERSION=1.8.2

# Limite maximale de membres (optionnel — non défini = illimité)
# Les comptes bannis ne sont PAS comptés dans cette limite.
# Exemple : NODYX_MAX_MEMBERS=50
# NODYX_MAX_MEMBERS=

# ── Serveur ───────────────────────────────────────────────────────────────────

# Port d'écoute de l'API backend
PORT=3000

# Adresse d'écoute — 0.0.0.0 pour accepter toutes les interfaces
HOST=0.0.0.0

# ── Authentification ──────────────────────────────────────────────────────────

# Secret JWT — OBLIGATOIRE en production, doit être long (32+ caractères aléatoires)
# Générez-en un avec : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=CHANGEZ_MOI_EN_PRODUCTION_UTILISEZ_UNE_VALEUR_ALEATOIRE_LONGUE

# ── Base de données PostgreSQL ────────────────────────────────────────────────

DB_HOST=localhost
DB_PORT=5432
DB_NAME=nodyx
DB_USER=nodyx_user
DB_PASSWORD=votre_mot_de_passe_postgres
# DB_SSL=true          # Activer le TLS pour les connexions PostgreSQL distantes (managed DB, ex: Supabase, Neon)

# ── Cache Redis ───────────────────────────────────────────────────────────────
# Redis est utilisé pour le rate limiting et le suivi des utilisateurs en ligne.

REDIS_HOST=localhost
REDIS_PORT=6379
# Redis password (laisser vide si Redis est sur localhost sans auth)
REDIS_PASSWORD=

# ── Environnement ─────────────────────────────────────────────────────────────
# development | production
# En production : les logs sont moins verbeux, les erreurs ne fuient pas de stack traces
NODE_ENV=production

# ── Email (optionnel — réinitialisation de mot de passe) ─────────────────────
# Si non configuré, seul un admin peut générer des liens de reset depuis /admin/members.
# Compatible avec tous les serveurs SMTP : Gmail, Mailgun, Resend, OVH, etc.
#
# Exemple Gmail :
#   SMTP_HOST=smtp.gmail.com | SMTP_PORT=587 | SMTP_SECURE=false
#   SMTP_USER=votre@gmail.com | SMTP_PASS=mot_de_passe_application
#
# Exemple Mailgun (EU) :
#   SMTP_HOST=smtp.eu.mailgun.org | SMTP_PORT=587 | SMTP_SECURE=false

# SMTP_HOST=smtp.exemple.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=noreply@votre-domaine.com
# SMTP_PASS=votre_mot_de_passe_smtp
# SMTP_FROM=noreply@votre-domaine.com   # optionnel, utilise SMTP_USER par défaut

# ── Annuaire global (nodyx.org) ──────────────────────────────────────────────
# Généré automatiquement lors de l'enregistrement via install.sh
# DIRECTORY_TOKEN=token_recu_lors_de_l_enregistrement
# DIRECTORY_API_URL=https://nodyx.org
# SELF_URL=http://127.0.0.1:3000

# Indexation globale : active l'annonce de vos threads sur nodyx.org/discover
# (opt-in — vos sujets publics apparaissent dans la recherche cross-instances)
NODYX_GLOBAL_INDEXING=true

# Pairs gossip protocol (optionnel — propagation directe sans hub central)
# GOSSIP_PEERS=https://ami1.fr,https://ami2.fr

# Fallback STUN (injecté automatiquement par install.sh en mode relay)
# STUN_FALLBACK_URLS=stun:stun.l.google.com:19302

# ── Web Push Notifications (optionnel) ───────────────────────────────────────
# Permet les notifications push navigateur même quand l'onglet est fermé.
# Génération des clés : cd nodyx-core && npx web-push generate-vapid-keys
# VAPID_SUBJECT doit être soit une URL soit mailto:email@votre-domaine.com
#
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:admin@votre-domaine.com

# ── Twitch API (optionnel — widget stream homepage) ─────────────────────────
# Nécessaire UNIQUEMENT pour que le widget Twitch détecte le statut live et
# affiche un stream de fallback depuis une catégorie quand la chaîne principale
# est offline. Sans ces credentials, le widget marche en mode embed pur.
#
# 1. Va sur https://dev.twitch.tv/console/apps
# 2. "Register Your Application" — nom libre, OAuth Redirect URL : http://localhost (non utilisé)
# 3. Category : "Application Integration" — copie Client ID + génère un Client Secret
#
# TWITCH_CLIENT_ID=
# TWITCH_CLIENT_SECRET=

# ── Nodyx Signet (authentificateur PWA, optionnel) ───────────────────────────
# URL de la PWA Signet — nécessaire pour le CORS côté nexus-core
# SIGNET_URL=https://signet.nodyx.org

# ── Cloudflare (optionnel — sous-domaine automatique *.nodyx.org) ────────────
# Renseigné automatiquement par install.sh
# VPS_IP=
# CF_TOKEN=
# CF_ZONE_ID=

# ── Honeypot & Sécurité ───────────────────────────────────────────────────────
# Webhook Discord pour les alertes honeypot (optionnel)
# HONEYPOT_DISCORD_WEBHOOK=https://discord.com/api/webhooks/...

# Secret pour générer les rapports CERT (GET /_hp_cert/:id)
# Doit être long et aléatoire — si absent, utilise JWT_SECRET
# CERT_REPORT_SECRET=

# ── MISP — Partage de renseignement (optionnel) ───────────────────────────────
# MISP (Malware Information Sharing Platform) — compatible CERT-FR / Europol / Interpol
# Si configuré, les incidents honeypot significatifs sont publiés automatiquement.
#
# MISP_URL=https://misp.votre-instance.fr
# MISP_API_KEY=votre_cle_api_misp
# MISP_ORG_ID=1
# MISP_DISTRIBUTION=0    # 0=organisation seulement, 1=communauté, 3=toutes les instances
