# ══════════════════════════════════════════════════════════════════════════════
#  NEXUS — Configuration de l'instance
#  Copiez ce fichier en .env et adaptez les valeurs.
#  Ne committez JAMAIS votre .env dans git.
# ══════════════════════════════════════════════════════════════════════════════

# ── Identité de la communauté ─────────────────────────────────────────────────
# Ces valeurs définissent votre instance. Une instance = une communauté.

# Nom affiché de la communauté (apparaît dans le titre, les balises meta, etc.)
NEXUS_COMMUNITY_NAME=Ma Communauté

# Description courte (utilisée pour le SEO, la page d'accueil, le RSS)
NEXUS_COMMUNITY_DESCRIPTION=La communauté dédiée à [votre sujet].

# Slug unique de la communauté — lettres minuscules, chiffres, tirets uniquement
# Exemple : linux, gaming, dev-web, photo
NEXUS_COMMUNITY_SLUG=ma-communaute

# Langue principale du contenu (code ISO 639-1)
# Utilisé pour la recherche full-text PostgreSQL et les balises HTML lang=""
# Valeurs supportées : fr, en, de, es, it, pt, nl
NEXUS_COMMUNITY_LANGUAGE=fr

# Pays (code ISO 3166-1 alpha-2, pour les balises meta geo)
NEXUS_COMMUNITY_COUNTRY=FR

# ── Serveur ───────────────────────────────────────────────────────────────────

# Port d'écoute de l'API backend
PORT=3000

# Adresse d'écoute — 0.0.0.0 pour accepter toutes les interfaces
HOST=0.0.0.0

# ── Authentification ──────────────────────────────────────────────────────────

# Secret JWT — OBLIGATOIRE en production, doit être long (32+ caractères aléatoires)
# Générez-en un avec : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=CHANGEZ_MOI_EN_PRODUCTION_UTILISEZ_UNE_VALEUR_ALEATOIRE_LONGUE

# ── Base de données PostgreSQL ────────────────────────────────────────────────

DB_HOST=localhost
DB_PORT=5432
DB_NAME=nexus
DB_USER=nexus_user
DB_PASSWORD=votre_mot_de_passe_postgres

# ── Cache Redis ───────────────────────────────────────────────────────────────
# Redis est utilisé pour le rate limiting et le suivi des utilisateurs en ligne.

REDIS_HOST=localhost
REDIS_PORT=6379

# ── Environnement ─────────────────────────────────────────────────────────────
# development | production
# En production : les logs sont moins verbeux, les erreurs ne fuient pas de stack traces
NODE_ENV=production

# ── Email (optionnel — réinitialisation de mot de passe) ─────────────────────
# Si non configuré, seul un admin peut générer des liens de reset depuis /admin/members.
# Compatible avec tous les serveurs SMTP : Gmail, Mailgun, Resend, OVH, etc.
#
# Exemple Gmail :
#   SMTP_HOST=smtp.gmail.com | SMTP_PORT=587 | SMTP_SECURE=false
#   SMTP_USER=votre@gmail.com | SMTP_PASS=mot_de_passe_application
#
# Exemple Mailgun (EU) :
#   SMTP_HOST=smtp.eu.mailgun.org | SMTP_PORT=587 | SMTP_SECURE=false

# SMTP_HOST=smtp.exemple.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=noreply@votre-domaine.com
# SMTP_PASS=votre_mot_de_passe_smtp
# SMTP_FROM=noreply@votre-domaine.com   # optionnel, utilise SMTP_USER par défaut
